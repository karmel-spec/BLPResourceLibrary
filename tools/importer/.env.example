# Copy this file to `.env`. See APS_IMPORT.md for how to get each value.

# --- Required: Autodesk app (PKCE flow, no client secret needed) ---
APS_CLIENT_ID=your-aps-app-client-id-here

# --- Optional: only for `node import.mjs files` (self-hosted downloads) ---
# Host F3D/STEP/STL on Supabase Storage so cards get real download buttons.
# Use the SERVICE ROLE key here (Supabase → Settings → API). Keep it secret —
# this file is gitignored. The public bucket below must exist and be public.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
STORAGE_BUCKET=models
EXPORT_FORMATS=step,stl
